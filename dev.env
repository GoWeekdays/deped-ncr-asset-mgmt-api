# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
SECRET_KEY=change_me_secret_key

# ---------------------------------------------------------------------------
# MongoDB
# ---------------------------------------------------------------------------
MONGO_URI=mongodb://localhost:27017
MONGO_DB=deped_ncr_asset_mgmt

# ---------------------------------------------------------------------------
# Mailer (SMTP)
# ---------------------------------------------------------------------------
MAILER_TRANSPORT_HOST=smtp.example.com
MAILER_TRANSPORT_PORT=465
MAILER_TRANSPORT_SECURE=true
[email protected]
MAILER_PASSWORD=change_me_mailer_password

# ---------------------------------------------------------------------------
# Auth Tokens / OTP
# ---------------------------------------------------------------------------
ACCESS_TOKEN_SECRET=access_token_secret
REFRESH_TOKEN_SECRET=refresh_token_secret
ACCESS_TOKEN_EXPIRY=15s
REFRESH_TOKEN_EXPIRY=30d
APP_ACCOUNT=http://localhost:3000
OTP_FORGET_PASSWORD_DURATION=10 minutes
OTP_USER_INVITE_DURATION=3 days
OTP_UPDATE_EMAIL_DURATION=10 minutes

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---------------------------------------------------------------------------
# Default Seed User
# ---------------------------------------------------------------------------
[email protected]
DEFAULT_USER_PASSWORD=change_me_user_password
DEFAULT_USER_FIRST_NAME=Default
DEFAULT_USER_LAST_NAME=User

# ---------------------------------------------------------------------------
# Default Role-Based Users
# ---------------------------------------------------------------------------
[email protected]
[email protected]
[email protected]
[email protected]

# ---------------------------------------------------------------------------
# DigitalOcean Spaces (S3-compatible)
# ---------------------------------------------------------------------------
SPACES_ACCESS_KEY=change_me_spaces_access_key
SPACES_SECRET_KEY=change_me_spaces_secret_key
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
SPACES_REGION=nyc3
SPACES_BUCKET=deped-ncr-asset-mgmt

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Entity Defaults
# ---------------------------------------------------------------------------
DEFAULT_ENTITY_NAME=DEPED NCR
DEFAULT_FUND_CLUSTER=M003
